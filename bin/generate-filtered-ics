#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use SportClimbing\IcsGenerator\CalendarFactory;
use SportClimbing\IcsGenerator\CalendarFilter;
use SportClimbing\IcsGenerator\FilterParams;
use SportClimbing\IcsGenerator\IcsGenerator;

$fixtureFile = $argv[1] ?? 'tests/fixtures/sample-calendar.json';
$outputFile  = $argv[2] ?? 'filtered.ics';

// Parse filter params from CLI args: --discipline=boulder,lead --kind=final --category=men
$opts = getopt('', ['discipline::', 'kind::', 'category::']);

$disciplines = isset($opts['discipline']) ? explode(',', $opts['discipline']) : ['boulder'];
$kinds       = isset($opts['kind']) ? explode(',', $opts['kind']) : ['final'];
$categories  = isset($opts['category']) ? explode(',', $opts['category']) : [];

if (!file_exists($fixtureFile)) {
    echo "Fixture not found: {$fixtureFile} — skipping\n";
    exit(0);
}

$json = json_decode(file_get_contents($fixtureFile), true);

if (!is_array($json) || !isset($json['events'])) {
    fwrite(STDERR, "Invalid fixture: missing 'events' key\n");
    exit(1);
}

$params = new FilterParams($disciplines, $kinds, $categories);
$filtered = CalendarFilter::apply($json['events'], $params);

$gen = new IcsGenerator(new CalendarFactory(), '-//ifsc//ical//EN', 'PT1H', 'IFSC');
file_put_contents($outputFile, $gen->generateForEvents($filtered));

$veventCount = substr_count(file_get_contents($outputFile), 'BEGIN:VEVENT');
echo "Generated {$outputFile}: {$veventCount} VEVENTs (filtered)\n";
